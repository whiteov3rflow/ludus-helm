# ─── Platform ──────────────────────────────────────────
# APP_ENV: production | development | test
# docker-compose overrides this to "production" inside the container, which
# triggers `alembic upgrade head` in the FastAPI lifespan handler.
APP_ENV=development

# Long, random string. Used for JWT signing. Rotate invalidates all sessions.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Bind address/port for uvicorn. Container always binds 0.0.0.0:8000; these
# are only used when running the backend outside Docker.
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Instructor admin account (bootstrap) ──────────────
# Created on first startup if no user with this email exists. Updating the
# password here after first boot does NOT rotate it — change it via the API.
ADMIN_EMAIL=admin@insec.ml
ADMIN_PASSWORD=change-me-strong-password

# ─── Database ──────────────────────────────────────────
# Host:      sqlite:///./data/insec.db
# Container: sqlite:////app/data/insec.db  (set automatically by compose)
# The ./data directory is mounted into the container at /app/data, so the DB
# file itself persists across `docker compose down/up` cycles.
DATABASE_URL=sqlite:///./data/insec.db

# ─── Public URL ────────────────────────────────────────
# Used to build invite links emailed/shared with students, and added to the
# CORS allow-list. No trailing slash.
PUBLIC_BASE_URL=http://localhost:8000

# ─── Invite settings ───────────────────────────────────
# How long a single-use student invite token is valid for (hours).
INVITE_TOKEN_TTL_HOURS=168  # 7 days

# ─── File storage ──────────────────────────────────────
# Where WireGuard .conf files returned from Ludus are cached for download.
# Host:      ./data/configs
# Container: /app/data/configs  (set automatically by compose)
CONFIG_STORAGE_DIR=./data/configs

# ─── Ludus server(s) ───────────────────────────────────
# Primary Ludus instance the platform talks to.
LUDUS_DEFAULT_URL=https://198.51.100.1:8080
LUDUS_DEFAULT_API_KEY=your-ludus-admin-api-key-here
# Set to true only if the Ludus server presents a trusted cert. Lab/self-
# signed deployments should leave this false.
LUDUS_DEFAULT_VERIFY_TLS=false

# Additional Ludus instances will follow the LUDUS_<NAME>_URL /
# LUDUS_<NAME>_API_KEY / LUDUS_<NAME>_VERIFY_TLS pattern in Phase 2.
